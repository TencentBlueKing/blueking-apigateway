meta {
  name: app-sse-delete-session
  type: http
  seq: 12
}

delete {
  url: {{scheme}}://{{host}}/api/bk-apigateway/prod/api/v2/mcp-servers/httpbin-mcp-server-sse/application/sse
  body: none
  auth: none
}

headers {
  X-Bkapi-Authorization: {"bk_app_code": "{{bk_app_code}}", "bk_app_secret": "{{bk_app_secret}}"}
  Mcp-Session-Id: {{app_sse_session_id}}
}

assert {
  res.status: eq 200
}

meta {
  name: user-streamable-http-tools-call
  type: http
  seq: 7
}

post {
  url: {{scheme}}://{{host}}/api/bk-apigateway/prod/api/v2/mcp-servers/httpbin-mcp-server/mcp
  body: json
  auth: none
}

headers {
  X-Bkapi-Authorization: {"bk_app_code": "{{bk_app_code}}", "bk_app_secret": "{{bk_app_secret}}", "access_token": "{{access_token}}"}
  Content-Type: application/json
  Accept: application/json, text/event-stream
  Mcp-Session-Id: {{user_streamable_session_id}}
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call",
    "params": {
      "name": "httpbin_get",
      "arguments": {}
    }
  }
}

assert {
  res.status: eq 200
  res.body.jsonrpc: eq 2.0
  res.body.result.content: isDefined
}

meta {
  name: app-streamable-http-initialize
  type: http
  seq: 1
}

post {
  url: {{scheme}}://{{host}}/api/bk-apigateway/prod/api/v2/mcp-servers/httpbin-mcp-server/application/mcp
  body: json
  auth: none
}

headers {
  X-Bkapi-Authorization: {"bk_app_code": "{{bk_app_code}}", "bk_app_secret": "{{bk_app_secret}}"}
  Content-Type: application/json
  Accept: application/json, text/event-stream
}

body:json {
  {
    "jsonrpc": "2.0",
    "id": 1,
    "method": "initialize",
    "params": {
      "protocolVersion": "2024-11-05",
      "capabilities": {},
      "clientInfo": {
        "name": "e2e-test-client",
        "version": "1.0.0"
      }
    }
  }
}

assert {
  res.status: eq 200
}

script:post-response {
  var sessionId = res.headers['mcp-session-id'];
  if (sessionId) {
    bru.setVar("app_streamable_session_id", sessionId);
  }
}

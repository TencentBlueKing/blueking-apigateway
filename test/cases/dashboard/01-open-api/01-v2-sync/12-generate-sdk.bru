meta {
  name: generate-sdk
  type: http
  seq: 12
}

post {
  url: {{scheme}}://{{host}}/api/bk-apigateway/prod/api/v2/sync/gateways/{{gateway_name}}/sdks/
  body: json
  auth: none
}

headers {
  X-Bkapi-Authorization: {"bk_app_code": "{{bk_app_code}}", "bk_app_secret": "{{bk_app_secret}}"}
  Content-Type: application/json
}

body:json {
  {
    "resource_version": "{{resource_version}}",
    "languages": ["python"],
    "version": "{{resource_version}}"
  }
}

assert {
  res.status: eq 201
  res.body.data: isDefined
}

tests {
  var data = res.getBody();
  test("status is 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
  test("response has sdk data", function() {
    expect(data.data).to.not.be.undefined;
  });
}

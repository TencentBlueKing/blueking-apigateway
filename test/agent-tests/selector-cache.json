{
  "_meta": {
    "description": "Pre-built selector cache for agent-test skill. Avoids reading Vue source files at runtime.",
    "source": "Extracted from test/agent-tests/AGENTS.md knowledge base",
    "lastUpdated": "2026-03-26"
  },
  "login": {
    "chineseForm": {
      "username": "#user",
      "password": "#password",
      "submitBtn": ".login-btn"
    },
    "englishForm": {
      "username": "role=textbox[name='Please enter your username']",
      "password": "role=textbox[name='Please enter your password']",
      "submitBtn": "role=button[name='Log in']"
    },
    "detection": "#user",
    "successIndicator": "text=新建网关"
  },
  "home": {
    "url": "/",
    "selectors": {
      "searchInput": "input[placeholder='请输入网关名称']",
      "sortDropdown": ".select-cls",
      "typeFilter": ".title-container .bk-select:first-child",
      "createGatewayBtn": "text=新建网关",
      "gatewayItems": ".table-item",
      "gatewayName": ".table-item .name",
      "resourceCount": ".table-item .pl-4",
      "actionButtons": ".table-item button",
      "footer": ".footer-container",
      "footerLinks": ".footer-container a"
    },
    "createGatewayForm": {
      "nameInput_standard": "input[placeholder*='请输入小写字母、数字、连字符']",
      "nameInput_programmable": "input[placeholder*='只能包含小写字母']",
      "typeRadio_standard": ".bk-radio-button:has-text('普通网关')",
      "typeRadio_programmable": ".bk-radio-button:has-text('可编程网关')",
      "submitBtn": "text=提交",
      "closeBtn": ".bk-sideslider-close",
      "formError": ".bk-form-error",
      "confirmLeaveBtn": ".bk-infobox button"
    },
    "sortOptions": ["更新时间", "创建时间", "字母 A-Z"],
    "filterOptions": ["全部", "普通网关", "可编程网关"]
  },
  "resourceConfig": {
    "url": "/:id/resource/setting",
    "selectors": {
      "table": ".bk-table",
      "tableRows": ".bk-table-row",
      "editBtn": "tr button:has-text('编辑')",
      "cloneBtn": "tr button:has-text('克隆')",
      "deleteBtn": "tr button:has-text('删除')",
      "exportBtn": "button:has-text('导出')",
      "importBtn": "button:has-text('导入')",
      "searchInput": "input[placeholder*='搜索']",
      "resourceNameLink": "[cursor=pointer]"
    },
    "sidebar": {
      "tabs": ["资源配置", "插件管理", "资源文档"],
      "editBtn": "button:has-text('编辑')",
      "deleteBtn": "button:has-text('删除')",
      "addPluginBtn": "text=添加插件",
      "pluginEditIcon": ".icon-ag-edit-line",
      "pluginDeleteIcon": ".icon-ag-delet"
    }
  },
  "resourceCreate": {
    "url": "/:id/resource/create",
    "selectors": {
      "nameInput": "input[placeholder*='由字母、数字、下划线']",
      "descInput": "input[placeholder='请输入描述']",
      "tagSelect": "nth=1 >> input[placeholder='请选择']",
      "requestMethodSelect": "nth=2 >> input[placeholder='请选择']",
      "requestPathInput": "nth=0 >> input[placeholder*='斜线']",
      "serviceSelect": "nth=3 >> input[placeholder='请选择']",
      "backendMethodSelect": "nth=4 >> input[placeholder='请选择']",
      "backendPathInput": "nth=1 >> input[placeholder*='斜线']",
      "submitBtn": "text=提交",
      "formError": ".bk-form-error"
    },
    "notes": {
      "serviceSelect": "CRITICAL: 5 selects on page with placeholder='请选择'. Index: 0=gateway, 1=tag, 2=request method, 3=SERVICE, 4=backend method. Must select 'default' service or submit fails.",
      "nameUniqueness": "Names are globally unique per gateway including camelCase. Always use timestamp suffix."
    }
  },
  "resourceVersion": {
    "url": "/:id/resource/version",
    "selectors": {
      "table": ".bk-table",
      "versionRows": ".bk-table-row",
      "sdkTab": "text=SDK"
    },
    "notes": {
      "sdkTab": "May not be visible — feature flag dependent"
    }
  },
  "stageOverview": {

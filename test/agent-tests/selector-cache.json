  "pluginManagement": {
    "wizardStep1": {
      "description": "Select plugin from card list",
      "categories": ["安全", "转换", "流量", "AI", "通用", "认证", "校验", "缓存"],
      "nextBtn": "text=下一步",
      "note": "Must scroll down to see all plugins"
    },
    "wizardStep2": {
      "description": "Configure plugin form",
      "submitBtn": "text=确定"
    },
    "availablePlugins": [
      "access_token来源", "强制X-Bk-Username", "CORS", "限制请求体大小",
      "用户访问限制", "IP访问保护", "频率控制", "流量染色",
      "Header转换", "mocking", "故障注入", "请求校验",
      "代理缓存", "熔断", "重定向", "Response转换"
    ],
    "notes": "Once added, plugin disappears from select list. Edit/delete via icon-ag-edit-line and icon-ag-delet icons."
  },
  "commonPatterns": {
    "dropdownSelect": {
      "steps": ["Escape", "wait(100)", "click(selector, force:true)", "wait(300)", "click(.bk-select-option hasText)", "wait(800)"]
    },
    "emptyValidation": {
      "steps": ["fill('a')", "fill('')", "blur()", "wait(300)"],
      "note": "Empty field validation requires fill-then-clear-then-blur"
    },
    "closeSlider": {
      "steps": ["click(.bk-sideslider-close, force:true)", "wait(300)", "click(.bk-infobox button hasText(确定|确认|离开))"]
    }
  },
  "bkuiComponents": {
    "BkSelect": {
      "options": ".bk-select-option",
      "trigger": "input[placeholder='请选择']"
    },
    "BkSwitcher": {
      "toggle": ".bk-switcher",
      "checkedClass": "is-checked"
    },
    "BkTable": {
      "rows": "tr",
      "header": "thead tr",
      "rowButtons": "tr button"
    },
    "BkSideslider": {
      "content": ".bk-sideslider-content",
      "footer": ".bk-sideslider-footer",
      "close": ".bk-sideslider-close"
    },
    "BkInfoBox": {
      "container": ".bk-infobox",
      "buttons": ".bk-infobox button"
    },
    "BkMessage": {
      "container": ".bk-message"
    }
  }

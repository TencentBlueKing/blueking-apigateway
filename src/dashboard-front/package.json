{
  "name": "blueking-api-gateway",
  "version": "1.22.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node replace-index-html.js index.dev.html && vite",
    "dev:tenant": "node replace-index-html.js index.dev.html && vite --mode tenant",
    "build": "node replace-index-html.js index.prod.html && run-p type-check \"build-only {@}\" --",
    "preview": "node replace-index-html.js index.dev.html && vite preview",
    "build-only": "node replace-index-html.js index.prod.html && vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint:ci": "eslint .",
    "lint": "run-s lint:*",
    "symlink-dot-agents:codebuddy": "node create-codebuddy-symlink.js"
  },
  "dependencies": {
    "@blueking/bk-user-display-name": "1.0.3-beta.7",
    "@blueking/bk-user-selector": "^0.0.38",
    "@blueking/date-picker": "2.0.0-beta.48",
    "@blueking/login-modal": "^1.0.6",
    "@blueking/login-userinfo": "^0.0.13",
    "@blueking/notice-component": "^2.0.5",
    "@blueking/release-note": "0.0.1-beta.17",
    "@blueking/status-tag": "^1.2.1",
    "@blueking/tdesign-ui": "0.0.2-beta.13",
    "@blueking/xss-filter": "^0.0.10",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^13.0.9",
    "@unocss/reset": "^66.6.8",
    "@vueuse/components": "^14.1.0",
    "@vueuse/core": "^13.6.0",
    "@vueuse/integrations": "^13.6.0",
    "@vueuse/router": "^13.6.0",
    "axios": "^1.16.1",
    "bkui-vue": "2.0.2-beta.93",
    "change-case": "^5.4.4",
    "dayjs": "^1.11.13",
    "echarts": "^5.6.0",
    "highlight.js": "^11.11.1",
    "js-cookie": "^3.0.5",
    "js-yaml": "^4.1.1",
    "json-schema": "^0.4.0",
    "jsonpath-plus": "^10.3.0",
    "jwt-decode": "^4.0.0",
    "lodash-es": "^4.18.1",
    "markdown-it": "^13.0.2",
    "mavon-editor": "3.0.2",
    "moment": "^2.30.1",
    "monaco-editor": "^0.52.2",
    "pinia": "^3.0.4",
    "qs": "^6.15.2",
    "reselect": "^5.1.1",
    "semver": "^7.7.2",
    "tdesign-vue-next": "^1.18.0",
    "to-json-schema": "^0.2.5",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-request": "^2.0.4",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@rolldown/pluginutils": "1.0.0-beta.29",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/js-cookie": "^3.0.6",
    "@types/json-schema": "^7.0.15",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.16.5",
    "@types/qs": "^6.15.1",
    "@types/semver": "^7.7.0",
    "@types/to-json-schema": "^0.2.4",
    "@unocss/preset-wind3": "^66.6.8",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.0.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-oxlint": "^1.65.0",
    "eslint-plugin-vue": "^10.9.1",
    "jiti": "^2.7.0",
    "less": "^4.4.0",
    "lint-staged": "^16.1.2",
    "npm-run-all2": "^9.0.0",
    "oxlint": "^1.65.0",
    "postcss-html": "^1.8.0",
    "sass-embedded": "^1.99.0",
    "simple-git-hooks": "^2.13.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-order": "^7.0.1",
    "symlink-dir": "^10.0.1",
    "typescript": "^5.9.3",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-turbo-console": "^2.3.2",
    "vite": "^7.3.3",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^2.2.12"
  },
  "simple-git-hooks": {
    "pre-commit": "cd src/dashboard-front && npx lint-staged && npm run type-check",
    "commit-msg": "cd src/dashboard-front && npx commitlint --edit $1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=20.19.3"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "flatted": "^3.4.2",
    "minimatch": ">=3.1.5 <9.0.0 || >=9.0.7"
  },
  "resolutions": {
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "flatted": "^3.4.2",
    "minimatch": ">=3.1.5 <9.0.0 || >=9.0.7"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "flatted": "^3.4.2",
      "minimatch": ">=3.1.5 <9.0.0 || >=9.0.7"
    }
  }
}

{
  "/mcp-marketplace/categories/": {
    "get": {
      "operationId": "mcp-marketplace_categories_list",
      "description": "获取 MCP 市场分类列表",
      "parameters": [
        {
          "name": "limit",
          "in": "query",
          "description": "Number of results to return per page.",
          "required": false,
          "type": "integer"
        },
        {
          "name": "offset",
          "in": "query",
          "description": "The initial index from which to return the results.",
          "required": false,
          "type": "integer"
        },
        {
          "name": "keyword",
          "in": "query",
          "description": "MCPServer 筛选条件，支持模糊匹配 MCPServer 名称或描述",
          "required": false,
          "type": "string"
        },
        {
          "name": "categories",
          "in": "query",
          "description": "分类筛选，支持单个或多个分类名称，多个分类以逗号分隔",
          "required": false,
          "type": "string"
        },
        {
          "name": "order_by",
          "in": "query",
          "description": "排序方式",
          "required": false,
          "type": "string",
          "enum": [
            "updated_time",
            "-updated_time",
            "created_time",
            "-created_time",
            "name",
            "-name"
          ],
          "default": "-updated_time"
        }
      ],
      "responses": {
        "200": {
          "description": "",
          "schema": {
            "type": "object",
            "properties": {
              "data": {
                "required": [
                  "count",
                  "results"
                ],
                "type": "object",
                "properties": {
                  "count": {
                    "type": "integer"
                  },
                  "results": {
                    "type": "array",
                    "items": {
                      "$ref": "#/definitions/apigateway.apis.web.mcp_marketplace.serializers.MCPServerCategoryOutputSLZ"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "tags": [
        "WebAPI.MCPServer"
      ]
    },
    "parameters": []
  },
